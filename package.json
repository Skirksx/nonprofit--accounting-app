{
  "name": "nonprofit-accounting-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "dev:render": "node --experimental-strip-types src/server.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply nonprofit_accounting --local",
    "db:migrate:remote": "wrangler d1 migrations apply nonprofit_accounting --remote",
    "test": "node --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.18.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0"
  }
}
